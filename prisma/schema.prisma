generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntegrationProvider {
  SHOPIFY
  META
}

model Shop {
  id         String @id @default(cuid())
  shopDomain String @unique

  installedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Per-shop settings (MVP). Shape enforced in src/lib/settings.ts
  settings Json?

  tokens   IntegrationToken[]
  Briefing Briefing[]
}

model IntegrationToken {
  id       String              @id @default(cuid())
  provider IntegrationProvider
  shopId   String
  shop     Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)

  scopes   String
  // Encrypted token at rest (AES-256-GCM, see src/lib/crypto.ts)
  tokenEnc String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, shopId])
}

model Briefing {
  id     String  @id @default(cuid())
  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: SetNull)

  // YYYY-MM-DD
  date        String
  generatedAt DateTime @default(now())

  // Full response payload for quick iteration
  payload Json

  createdAt DateTime @default(now())

  @@unique([shopId, date], name: "shopId_date")
  @@index([shopId, date])
}
